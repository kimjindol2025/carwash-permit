# ================================================
# 세차장 허가 자동 체크 서비스 - 환경 변수 설정
# ================================================
# 이 파일을 복사하여 .env를 생성하세요:
# cp .env.example .env

# ========== 서버 설정 ==========
NODE_ENV=development              # development | production | test
PORT=40090                        # 개발 포트 (배포: 35000)

# ========== 보안 설정 ==========
ADMIN_PASSWORD=carwash2024        # 🔐 관리자 패스워드 (변경 권장!)

# ========== 공공 API 키 ==========
# Mock 모드 사용 시 필수 아님 (USE_MOCK=true)
# 실제 API 사용 시 아래 키 필요

# VWorld API (지도 데이터)
VWORLD_KEY=D8C6FAA0-D909-3BA4-8E7D-F17178F57932

# 행안부 도로명주소 API (주소 검색)
# https://www.juso.go.kr/addrlink/addressBuildDevGuide.do
JUSO_KEY=

# 국토부 건축물대장 API (건축물 정보)
# https://data.go.kr/
DATA_API_KEY=

# ========== Mock 모드 ==========
# Mock 데이터로 테스트 시: true
# 실제 API 사용 시: false
USE_MOCK=false

# ========== 배포 설정 ==========
SUBDOMAIN=carwash                 # 서브도메인
DOMAIN=carwash.dclub.kr           # 도메인
DEPLOYED=true                     # 배포 여부

# ========== 데이터베이스 ==========
DB_PATH=./db/init.db              # SQLite 데이터베이스 경로

# ========== 로깅 ==========
LOG_LEVEL=info                    # debug | info | warn | error
LOG_DIR=./logs                    # 로그 파일 디렉토리

# ========== 타임아웃 설정 ==========
RESPONSE_TIMEOUT=30000            # ms (30초)
DB_TIMEOUT=5000                   # ms (5초)

# ========== 레이트 리미팅 ==========
RATE_LIMIT_WINDOW=15              # 분
RATE_LIMIT_MAX_REQUESTS=100       # 요청 수

# ========== CORS 설정 ==========
CORS_ORIGIN=*                     # 허용할 origin (* = 모두 허용)

# ========== 세션 설정 ==========
SESSION_TIMEOUT=86400000          # ms (24시간)
WORKFLOW_SESSION_TIMEOUT=86400    # 초 (24시간)

# ================================================
# 📋 주의사항
# ================================================
# 1. .env 파일은 절대 git에 커밋하지 마세요
# 2. 패스워드와 API 키는 안전하게 보관하세요
# 3. 프로덕션 환경에서는 환경변수로 주입하세요
# 4. 배포 시 .env.example만 커밋하고 .env는 .gitignore에 추가
# ================================================
